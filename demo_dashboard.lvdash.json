{
  "datasets": [
    {
      "name": "031aa9f1",
      "displayName": "Market Signals and Anomaly Insights Dataset",
      "queryLines": [
        "SELECT\n",
        "  market_id,\n",
        "  window_start,\n",
        "  anomaly_score,\n",
        "  volume,\n",
        "  trade_count,\n",
        "  imbalance,\n",
        "  reason_tags\n",
        "FROM parallax_demo.gold_parallax_signals"
      ],
      "catalog": "workspace",
      "schema": "parallax_demo"
    },
    {
      "name": "0dd90e2a",
      "displayName": "Market Anomaly Insights with Top Trade Signals",
      "queryLines": [
        "SELECT\n",
        "  market_id,\n",
        "  window_start,\n",
        "  anomaly_score,\n",
        "  volume,\n",
        "  trade_count,\n",
        "  imbalance,\n",
        "  reason_tags\n",
        "FROM parallax_demo.gold_parallax_signals\n",
        "ORDER BY anomaly_score DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "bac4abeb",
      "displayName": "Tesla Model Z Activity Anomaly Breakdown",
      "queryLines": [
        "SELECT\n",
        "  window_start,\n",
        "\n",
        "  MAX(CASE \n",
        "    WHEN anomaly_score <= 80 THEN anomaly_score \n",
        "  END) AS normal_activity,\n",
        "\n",
        "  MAX(CASE \n",
        "    WHEN anomaly_score > 80 THEN anomaly_score \n",
        "  END) AS whale_activity\n",
        "\n",
        "FROM parallax_demo.gold_parallax_signals\n",
        "WHERE market_id = 'tesla_model_z_before_june_30'\n",
        "GROUP BY window_start\n",
        "ORDER BY window_start"
      ]
    }
  ],
